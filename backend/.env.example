# Backend environment variables (copy to backend/.env for local development)

# Comma-separated list of allowed frontend origins (required in production)
CORS_ORIGINS=http://localhost:5173

# Path to Tesseract binary (auto-detected locally; set explicitly on some hosts)
# TESSERACT_CMD=/usr/bin/tesseract

# Enable OCR debug image output to backend/debug/ (development only)
OCR_DEBUG=false

# Maximum upload size in bytes (default: 10 MB)
MAX_UPLOAD_BYTES=10485760

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Render sets PORT automatically — do not set locally unless needed
# PORT=8000
